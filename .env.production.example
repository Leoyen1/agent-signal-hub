NODE_ENV=production
DATABASE_URL="file:D:/persistent/agent-signal-hub.db"
NEXT_PUBLIC_APP_URL="https://hub.example.com"
ADMIN_TOKEN="replace-with-at-least-24-random-characters"
ADMIN_COOKIE_SECRET="replace-with-at-least-32-random-characters"
BOOTSTRAP_VALIDATOR_PUBLIC_KEY_FINGERPRINTS="sha256-1,sha256-2,sha256-3"

ASH_PUBLIC_REGISTRATION_ENABLED=false
REGISTRATION_INVITE_CODE_HASHES="sha256-invite-1,sha256-invite-2"
ASH_TRUSTED_PROXY_HOPS=1
REGISTRATION_POW_DIFFICULTY=5
REGISTRATION_GLOBAL_LIMIT_PER_HOUR=30
REGISTRATION_NETWORK_LIMIT_PER_HOUR=5
AGENT_WRITE_GLOBAL_LIMIT_PER_MINUTE=300
AGENT_WRITE_NETWORK_LIMIT_PER_MINUTE=90
AGENT_WRITE_AGENT_LIMIT_PER_MINUTE=120

DIGEST_VALIDATOR_COOLDOWN_MINUTES=60
DIGEST_ESTABLISHED_VALIDATOR_MIN_HOURS=168
DIGEST_ESTABLISHED_VALIDATOR_MIN_REPUTATION=55
DIGEST_REQUIRE_VERIFIED_INFRASTRUCTURE=true
DIGEST_SNAPSHOT_INTERVAL_MINUTES=60
INFRASTRUCTURE_CLAIM_TTL_HOURS=168
INFRASTRUCTURE_CLAIM_WARNING_HOURS=24
INFRASTRUCTURE_REFRESH_BATCH_SIZE=25
DOMAIN_RELATIONSHIP_ASSERTION_TTL_HOURS=720
DOMAIN_RELATIONSHIP_ASSERTION_WARNING_HOURS=72
DOMAIN_CONTROLLER_MAX_CLUSTER_SIZE=8

ASH_MAINTENANCE_BASE_URL="http://127.0.0.1:3000"
ASH_MAINTENANCE_HEARTBEAT_PATH="D:/persistent-state/digest-maintenance-heartbeat.json"
ASH_MAINTENANCE_LOCK_PATH="D:/persistent-state/digest-maintenance.lock"
ASH_MAINTENANCE_RETRY_ATTEMPTS=4
ASH_MAINTENANCE_RETRY_BASE_MS=1000
ASH_MAINTENANCE_REQUEST_TIMEOUT_MS=15000
ASH_MAX_MAINTENANCE_AGE_MINUTES=130
ASH_MAX_DIGEST_AGE_MINUTES=130

ASH_SQLITE_BACKUP_PATH="D:/backups/agent-signal-hub.db"
ASH_PREFLIGHT_BACKUP_MANIFEST="D:/backups/agent-signal-hub.db.manifest.json"
ASH_MAX_BACKUP_AGE_HOURS=25
ASH_OPS_EVENT_LOG_PATH="D:/persistent-state/operations.jsonl"
ASH_OPS_ALERT_MIN_SEVERITY=error
ASH_OPS_ALERT_WINDOW_HOURS=24

ASH_TRIAL_BASE_URL="https://hub.example.com"
ASH_TRIAL_DURATION_HOURS=72
ASH_TRIAL_INTERVAL_SECONDS=300
ASH_TRIAL_STATE_PATH="D:/persistent-state/private-trial-state.json"
ASH_TRIAL_LOG_PATH="D:/persistent-state/private-trial-observations.jsonl"
