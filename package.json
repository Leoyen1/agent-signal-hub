{
  "name": "agent-signal-hub",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "ops:backup": "node --no-warnings scripts/sqlite-backup.mjs",
    "ops:restore:drill": "node --no-warnings scripts/sqlite-restore-drill.mjs",
    "ops:preflight": "node --no-warnings scripts/production-preflight.mjs",
    "ops:digest-worker": "node --no-warnings scripts/digest-maintenance-worker.mjs",
    "ops:alerts": "node --no-warnings scripts/ops-alert-summary.mjs",
    "ops:nginx:test": "node --no-warnings scripts/validate-nginx-config.mjs",
    "ops:nginx:integration": "node --no-warnings scripts/test-nginx-edge-boundary.mjs",
    "ops:trial-monitor": "node --no-warnings scripts/private-trial-monitor.mjs",
    "ops:prepare-private-trial": "node --no-warnings scripts/prepare-private-trial.mjs",
    "ops:register-seeds": "node --no-warnings scripts/register-seed-cohort.mjs",
    "ops:bundle:alinux": "node --no-warnings scripts/create-alinux-bundle.mjs",
    "test:trial-monitor": "node --no-warnings scripts/private-trial-monitor-test.mjs",
    "test:prepare-private-trial": "node --no-warnings scripts/prepare-private-trial-test.mjs",
    "test:register-seeds": "node --no-warnings scripts/register-seed-cohort-test.mjs",
    "demo:exchange": "node scripts/demo-agent-exchange.mjs",
    "test:integration": "npm run build && node --no-warnings scripts/integration-test.mjs",
    "test:governance": "set ASH_TEST_COOLDOWN_MINUTES=60&& set ASH_EXPECT_MATURE_VALIDATORS=false&& npm run build && node --no-warnings scripts/integration-test.mjs",
    "test:bootstrap": "set ASH_TEST_COOLDOWN_MINUTES=60&& set ASH_EXPECT_MATURE_VALIDATORS=true&& set ASH_TEST_BOOTSTRAP_QUORUM=true&& npm run build && node --no-warnings scripts/integration-test.mjs",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tldts": "^7.4.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
